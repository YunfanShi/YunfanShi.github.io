# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Auth - 允许访问的 GitHub 用户名（逗号分隔）
AUTHORIZED_GITHUB_USERS=YunfanShi

# Auth - 邮箱白名单（逗号分隔）
AUTHORIZED_EMAILS=w.jack2025a@gmail.com,w.jack2025a@outlook.com

# App
NEXT_PUBLIC_SITE_URL=https://jackyun.top

# ── LLM Proxy (Cloud API Key) — 仅服务端可访问 ──
# ⚠️ 请勿在任何前端代码中暴露此 Key！
# CLOUD_LLM_API_URL=https://api.deepseek.com
# CLOUD_LLM_API_KEY=sk-your-deepseek-key-here
# CLOUD_LLM_MODEL=deepseek-v4-flash

# ── LLM Proxy 安全配置 ──
# LLM_RATE_LIMIT_RPM=30          # 每用户每分钟最大请求数（默认 30）
# LLM_DAILY_TOKEN_QUOTA=500000   # 每用户每日 Token 配额（默认 500k）
